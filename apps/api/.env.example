# Copy to .env and fill in values — never commit .env

# OpenAI API key (local dev only — in Lambda this comes from SSM)
OPENAI_API_KEY=sk-...

# Port for the local dev server (default: 3001)
PORT=3001

# Allowed CORS origin (default: http://localhost:4200)
ALLOWED_ORIGIN=http://localhost:4200

# Origin verify secret — leave empty for local dev, set in Lambda env for production
# ORIGIN_VERIFY_SECRET=
