{
  "name": "@einarinau/web",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:fe": "pnpm --filter @einarinau/web dev",
    "dev:fe:prod-api": "pnpm --filter @einarinau/web dev:prod-api",
    "dev:api": "pnpm --filter @einarinau/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format"
  },
  "dependencies": {
    "@types/node": "^20.17.19"
  }
}
